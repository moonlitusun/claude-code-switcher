{
  "name": "@sunday-sky/cc-switcher",
  "version": "1.0.1",
  "description": "CLI for switching Claude Code providers and models",
  "license": "MIT",
  "homepage": "https://github.com/rocsun/cc-switcher",
  "packageManager": "bun@1.2.16",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rocsun/cc-switcher.git"
  },
  "bugs": {
    "url": "https://github.com/rocsun/cc-switcher/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "cli",
    "openrouter",
    "model-switcher",
    "provider-switcher"
  ],
  "bin": {
    "cc-switcher": "./dist/bin/cc-switcher.js",
    "ccs": "./dist/bin/cc-switcher.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bunx tsc --noEmit",
