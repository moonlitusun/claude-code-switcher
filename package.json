    "prepublishOnly": "bun run typecheck && bun test && bun run build"
  },
  "engines": {
    "bun": ">=1.2.16"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.0.0",
    "commander": "^9.5.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "bun-types": "^1.2.16",
    "typescript": "^5.8.3"
  }
}
